{# Imports ----------------------------------------------------------------------------------------------------------------------------- #}

{% from "components/section.njk" import section %}
{% from "components/container.njk" import container %}
{% from "components/announcementBanner.njk" import announcementBanner with context %}
{% from "components/toaster.njk" import toaster %}
{% from "components/button.njk" import button %}
{% from "components/textLockup.njk" import textLockup %}
{% from "components/divider.njk" import divider %}
{% from "components/markdown.njk" import markdown %}

{# Values ------------------------------------------------------------------------------------------------------------------------------ #}

{# Theme Values ------------------ #}

{% set htmlStyles = "scroll-smooth scroll-p-lg" %}
{% set bodyStyles = "bg-surface font-body text-neutral text-body-base antialiased flex flex-col min-h-dvh w-screen items-center" %}

{# Other ------------------ #}

{# ------------------------------------------------------------------------------------------------------------------------------------- #}

<!DOCTYPE html>
<html
    {% if showNavbar %} {# checks if the layout template includes the navbar or not #}
        x-data="{
            scrollable: true,
            hasScrolled: false,
            setHasScrolled() {
                if (window.scrollY > 0) {
                    this.hasScrolled = true
                } else {
                    this.hasScrolled = false
                }
            }
        }"
        @scroll.window="setHasScrolled()"
    {% endif %}
    lang="en"
    class="relative {{ htmlStyles }}">

    <head>
        {% include "snippets/htmlHead.njk" %}
    </head>

    <body
        :class="!scrollable && 'overflow-y-hidden'"
        class="{{ bodyStyles }}">

        {# Skip to content link #}
        <a class="absolute top-0 left-0 opacity-0 z-[-1111111]" href="#main" aria-label="skip to main content">Click to skip to main content</a>

        {% if global.bannerContent %}
            {{ announcementBanner({content: global.bannerContent }) }}
        {% endif %}


        {{ toaster() }}

        <main id="main" class="@container flex flex-col justify-center w-full grow {{ mainStyles }}">
            {% block content %}{% endblock %}
        </main>

        {% call section({tag:"footer"},{class:"bg-neutral text-neutral border-t border-neutral max-lg:pb-tube-lg"}) %}

            {% block footer %}{% endblock %}

            {% call container({size:"base", type: "cols-1", alignment: "center"}, {class:"py-xs"}) %}
                {{ markdown({content:global.footer, transform: true},{class:"w-full text-center"}) }}
            {% endcall %}

        {% endcall %}

        {% block bottomSheet %}{% endblock %}

{# ------------------------------------------------------------------------------------------------------------------------------------- #}

        {% if environment.env == 'dev' %}
            {% include "components/_developmentWidget.njk" %}
        {% endif %}

        {% include "snippets/scripts.njk" %}

    </body>
</html>
